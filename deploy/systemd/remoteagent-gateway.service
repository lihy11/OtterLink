[Unit]
Description=remoteagent JS gateway
After=network-online.target remoteagent-core.service
Wants=network-online.target remoteagent-core.service

[Service]
Type=simple
User=__SERVICE_USER__
Group=__SERVICE_GROUP__
WorkingDirectory=__ROOT_DIR__
EnvironmentFile=__ENV_FILE__
ExecStart=__ROOT_DIR__/scripts/run-gateway.sh
ExecReload=/bin/kill -HUP $MAINPID
Restart=always
RestartSec=2
TimeoutStopSec=20
KillSignal=SIGTERM
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
