# Gateway
APP_ID=replace_with_app_id
APP_SECRET=replace_with_app_secret
BIND=127.0.0.1:1127
CORE_BASE_URL=http://127.0.0.1:7211
CORE_INGEST_TOKEN=replace_with_strong_token
GATEWAY_EVENT_TOKEN=replace_with_strong_token
BRIDGE_INGEST_TOKEN=replace_with_strong_token
BRIDGE_NOTIFY_TOKEN=replace_with_strong_token
FEISHU_AUTH_MODE=pair_or_allow_from
PAIR_AUTH_TOKEN=replace_with_pair_token
ALLOW_FROM_OPEN_IDS=
PAIR_STORE_PATH=/var/lib/otterlink/pairings.json

# Rust core
CORE_BIND=127.0.0.1:7211
STATE_DB_PATH=/var/lib/otterlink/state.db
TODO_EVENT_LOG_PATH=/var/lib/otterlink/todo-events.jsonl
CLAUDE_HOME_DIR=/home/otterlink/.claude
CODEX_HOME_DIR=/home/otterlink/.codex
RENDER_MIN_UPDATE_MS=700

# Agent runtime
RUNTIME_MODE=acp
ACP_ADAPTER=claude_code
ACP_AGENT_CMD=
ACP_PROXY_URL=
CLAUDE_CODE_DEFAULT_PROXY_MODE=off
CODEX_DEFAULT_PROXY_MODE=on
CODEX_BIN=codex
CODEX_WORKDIR=/var/lib/otterlink/workspace
CODEX_SKIP_GIT_REPO_CHECK=true
